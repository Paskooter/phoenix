# Phoenix configuration — copy to `.env` and edit. Every variable here is optional unless
# marked REQUIRED; real environment variables always override .env values.
# Loaded automatically by every Phoenix service/launcher (packages/common/src/dotenv.js).

# ── Web portal / admin UI (packages/account) ────────────────────────────────
# REQUIRED to use the admin UI: password for /admin (unset = admin face disabled).
ADMIN_PASSWORD=
# The `region` written into adopted robots' credentials.json (any name; robots resolve
# it via the repoint script, not DNS, unless you set up <region>.jibo.com yourself).
ETCO_account_region=phx
# Where the account store persists (accounts/loops/tokens/sessions).
#ETCO_account_dataFile=packages/account/data/store.json
# Set true when serving the portal over HTTPS so session cookies are Secure.
#ETCO_account_secureCookies=true

# ── Hub auth ────────────────────────────────────────────────────────────────
# Secret that signs/verifies robot hub tokens. CHANGE THIS for any non-LAN deployment.
HUB_TOKEN_SECRET=dev-hub-token-secret
# true = hub accepts unauthenticated robots (LAN convenience). Set false for real auth.
DISABLE_AUTH=true

# ── Speech + LLM backends ───────────────────────────────────────────────────
# Parakeet ASR host (POST /transcribe). Unset = launcher probes REAL_PARAKEET, then mock.
#PARAKEET_URL=http://192.168.1.252:6972
#REAL_PARAKEET=http://192.168.1.252:6972
# OpenAI-compatible endpoint for the answer-skill + parser LLM fallback (e.g. LM Studio).
#LLM_URL=http://192.168.1.252:1234/v1
#LLM_MODEL=google/gemma-4-e4b
#REAL_LLM=http://192.168.1.252:1234/v1

# ── Personal report ─────────────────────────────────────────────────────────
# true = read user prefs from resources/report-prefsConfig.json (enables commute/calendar).
#PREFS_FROM_CONFIG=true
# Settings service host (none exists; leave unset -> SettingsFailed degradation).
#NET_settings=

# ── OTA update server (packages/ota) ────────────────────────────────────────
# Externally reachable base URL for package downloads (default: derived from request Host).
#OTA_PUBLIC_URL=
#ETCO_ota_dataDir=packages/ota/data
#ETCO_ota_manifest=packages/ota/manifest.json

# ── Service discovery (compose/native launchers set these; override to split hosts) ──
#NET_parser=localhost:9005
#NET_history=localhost:9006
#NET_data=localhost:9007
#NET_skills=
#NET_ota=localhost:9010
