{
    "id": "report-skill",
    "intents": [
        {
            "name": "launchPersonalReport",
            "entities": [],
            "memo": "Reactive"
        },
        {
            "name": "requestWeatherPR",
            "entities": [],
            "memo": "Reactive Weather"
        },
        {
            "name": "requestCommute",
            "entities": [],
            "memo": "Reactive Commute"
        },
        {
            "name": "requestCalendar",
            "entities": [],
            "memo": "Reactive Calendar"
        },
        {
            "name": "requestNews",
            "entities": [],
            "memo": "Reactive News"
        }
    ],
    "proactives": [
        {
            "memo": "Proactive",
            "topics": [],
            "contextRules": [
                {
                    "field": "PART_OF_DAY",
                    "matchRule": "CONTAINED_IN",
                    "value": [
                        {
                            "basic": "MORNING",
                            "detail": "EARLY"
                        },
                        {
                            "basic": "MORNING",
                            "detail": "MID"
                        },
                        {
                            "basic": "MORNING",
                            "detail": "LATE"
                        }
                    ]
                },
                {
                    "field": "DAY_OF_WEEK",
                    "matchRule": "CONTAINED_IN",
                    "value": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        5,
                        6
                    ]
                },
                {
                    "field": "TRIGGER_SOURCE",
                    "value": "SURPRISE",
                    "matchRule": "EXACT"
                },
                {
                    "field": "FOCUSED_PERSON",
                    "matchRule": "NOT",
                    "value": "UNKNOWN"
                }
            ],
            "IHRules": [
                {
                    "query":"PersonalReportLaunchCount7LastHours",
                    "matchRule": "LESS_THAN",
                    "value": 1
                }
            ],
            "settingsRules": [
                {
                    "skill": "report-skill",
                    "key": "offerProactively",
                    "matchRule": "EXACT",
                    "value": {"value": true}
                }
            ]
        }
    ],
    "IHQueries": {
        "PersonalReportLaunchCount7LastHours": {
            "type": "Count",
            "queryRules": [{
                "field": "skillID",
                "match": "EXACT",
                "value": "report-skill"
            }],
            "startTimeOffset": [-7, "hours"],
            "endTimeOffset": [0, "hours"]
        }
    },
    "settings": {
        "view": {
            "type": "skill",
            "index": 0,
            "title": "Personal report",
            "subtitle": "Add your commute, calendar and news",
            "icon": "personal_report_icon",
