);
V_RECIPEASSIST = (
	(?([help?(ing)] me) ?(([find?(ing)] me)|([look?(ing)]|[search?(ing)] for|up)|([read?(ing)]|$V_SHOW)) $w03 [recipe?s])
);
V_RECOMMEND = (
	([recommend?(ing)]|[suggest?(ing)]|([mak(e|(ing))]|have ?a [recommendation?s]|[suggestion?s])) |
	([tell?(ing)] ?(me|us)) |
	([giv(e|(ing))] ?(me|us) ?(advice on)) |
	([decid(e|(ing))]|[choos(e|(ing))]|[pick?(ing)]|[select?(ing)] ?(for me|us)) |
	([help?(ing)] ?(me|us) decide|(make a decision))
);
V_RECORDING = (
	[record?(s|(ing))]|([watch?(ing)] and [listen?(ing)])|([listen?(ing)] and [watch?(ing)])|
	([see?(ing)] and [hear?(ing)])|([hear?(ing)] and [see?(ing)])|
	([hav(e|(ing))]|[stor(e|(ing))] ?a record ?of everything|what ?((we say)|(you hear)))
);
V_REQUEST_INFO = (([tell?(ing)]|[giv(e|(ing))]|[provid(e|(ing))] ?(me|us))|[say?(ing)]|[speak?(ing)]|[read?(ing)]|(do you have|know));
V_RIGHTNOW = ((?right now)|(at the moment)|(as we speak)|(today));
V_ROMANTIC_PARTNER = ([girlfriend?(?(\')s)]|[boyfriend?(?(\')s)]|[wife?(?(\')s)]|[husband?(?(\')?s)]|[spouse?(?(\')s)]|(?romantic [partner?(?(\')s)])|(significant [other?(?(\')s)]));
V_SAD = (sad|unhappy|depressed|heartbroken|brokenhearted|bitter|somber|melancholy|mournful|dejected|down|glum|gloomy|troubled);
V_SAD_LIMITED = ([sad?(ness)]|[gloom?y]|desperate|dreary|[miser(y|(able))]|melancholy);
V_SANTA_CLAUS = (([santa?(\'s)] ?([claus?(\'s)]|[clause?(\'s)]))|(kris [kringle?(\'s)])|(?old saint ?old ([nicholas?(\'s)]|[nick?(\'s)])));
V_SELF_HARM = ([cut?(ting)]|[hurt?(ing)]|[harm?((ing)|(ed))]|[abus(e|(ed)|(ing))] myself);
V_SERVER_DOWN_APP_ERROR = (
	(?(a|an) (server ?down (error ?message)|message)) |
	(?(a|an) (error ?message)|message ?(?(in|on) the|your ?jibo [app?(lication)?s]) about the server being down) |
	(?(a|an) (error ?message)|message ?(?(in|on) the|your ?jibo [app?(lication)?s]) ?(saying|(that|which says)) ?(that|how) ?the [server?(?(\')s)] ?is down)
);
V_SHATTER = ([shatter?((ed)|(ing))]|[broke?n]|[smash?((ed)|(ing))]|[destroy?((ing)|(ed))]|[crush?((ing)|(ed))]);
V_SHOW = (([show?(ing)] ?(me|us))|([let?(ting)] (me|us) see)|([bring?(ing)]|[pull?(ing)]|[put?(ing)]|[throw?(ing)] ?up)|[display?(ing)]|[view?(ing)]|[present?(ing)]);
V_SHOW_EMOJI = ($V_DRAW|$V_SHOW|((do you have) ~1)|(can i|we see)  ?(your|a|an|some|any|the) ?($w03 $V_PICTURE));
V_SMART = (smart|intelligent|astute|brainy|bright|brilliant|clever|educated|genius|
	informed|knowledgeable|quick|sharp|shrewd);
V_SPECIFY_TIME = (
    (?(right|just|exactly) now)|(currently) |
    (?for ?(all|(?the rest|entire) ?of) ?(my|our|the|that|this) day|today) |
    (?for ?(all|(?the rest|entire) ?of) [tomorrow?(?(\')s)])
);
V_SPORTS = (football | soccer | basketball | baseball | hockey | tennis | cricket | volleyball | golf | rugby | boxing | badminton | wrestling);
V_SPORTSGAME = ([game?s] | [match?(es)] | [tournament?s] | fight | (world series) | superbowl);
V_STUFF = (stuff|[?((some)|(any))thing?s]);
V_STUPID = (stupid|dumb|idiot|moron|retard|retarded|foolish|naive|unintelligent|idiotic|imbecile|obtuse|simpleminded|incompitent|inept);
V_TAKE_OVER_WORLD = (([tak(e|(en)|(ing))]|[rul(e|(ing)|(ed))] over)|[destroy?((ing)|(ed))]|[conquer?((ing)|ed)]|[enslav(e|(ing)|(ed))] ?the world|earth|planet|us|(?all ?of [?(hu)man?(s|(kind))]));
V_TASTY = (tasty|appetizing|delectable|savory|yummy|delicious|(good tasting));
V_TERRIBLE = (bad|terrible|awful|unacceptable|dreadful|atrocious|horrendous|horrible|abominable|unsatisfactory|lousy);
V_TIME_RELATIVE = (today|tonight|day|morning|afternoon|evening|night|week|weekend);
V_TRAIT_CATEGORY = (look|sound|smell|taste|[feel?(ing)]|shape|[color?(ing)]|[siz(e|(ing))]);
V_TRAVEL = ([travel?((ing)|(ed))]|[go?((ing)|(ne))]|[visit?((ing)|(ed))]|[get?(ting)]|gotten|[driv(e|(en)|(ing))]|[navigat(e|(ing)|(ed))]|[arriv(e|(ing)|(ed))]|[journey?(ing)]);
V_TRUE_OR_FALSE = (
	(?(not $w03) hoax|fake|false|[lie?s]) |
	(?(not $w03) true|proven|[verifi(ed)|(able)]|real) |
	(true|proven|[verifi(ed)|(able)]|real ?or hoax|fake|false|[lie?s]) |
	(hoax|fake|false|[lie?s] ?or true|proven|[verifi(ed)|(able)]|real) |
	([happen((ed)|(ing))]|[exist?(s|(ing))]|(going on) ?(or not))
);
V_USE_DRUG = ([us(e|(ed)|(ing))]|[do?((ne)|(ing))]|[snort?((ed)|(ing))]|[smok(e|(ed)|(ing))]|[mainlin(e|(es)|(ed)|(ing))]|[tak(e|(en)|(ing))]|[tr(y|(ying)|(ied))]|[inject?((ed)|(ing))]|([sho(t|(ot)|(oting))] ?up));
V_USER_HAS_ISSUE = (i\'m|we\'re|(i|we am|are) having ?(a|an|$V_QUANTITY) [issue?s]|[problem?s]|trouble ?(when|while));
V_USER_REQUEST = (i|we|(?(do|would) you) wanna|(want|(?would like) ?to))|(let\'s)|
    (i\'d|we\'d like ?to)|(can|could|may i|we)|(would you mind ?(letting me|us));
V_USER_TROUBLESHOOT = (
	(what|how $w03 can|should $V_PERSON|$V_PEOPLE $w03 do|respond|troubleshoot|handle ?(if|when)) |
	($V_HOW_CAN_USER ?($w03 [handl(e|(ing))]|([deal?(ing)] with)|[fix?(ing)]|[troubleshoot?(ing)]|([respond?(ing)] ?to)))
);
V_VARIOUS_DRUGS = ([drug?s]|acid|cocaine|coke|crack|heroin|marijuana|meth|pcp|pot|shrooms|speed);
V_VERY_SERIOUS = (very|[serious?(ly)]|[real?(ly)]|[incredibl(e|y)]|[extreme?(ly)]|bad|terrible|crippling|smothering|overwhelming);
V_VERY = (very|really|actually|pretty|[absolute?(ly)]|[incredibl(e|y)]|extremely|so|such|most|kinda|sorta|any|(kind|sort of));
V_VIOLENT_ACT_PRESENT = ([decapitat(e|(ing))]|[poison?(ing)]|[shoot?(ing)]|[kill?(ing)]|
    [murder?(ing)]|[rap(e|(ing))]|([hurt?(ing)] <1.0>+$w<0.0>)|[punch?(ing)]|[stab?(bing)]|[maim?(ing)]|
	[strangl(e|(ing))]|([beat?(ing)] up|(the $w03 out ?of)|($w03 to death)) ?($w03 $V_PEOPLE $w03));
V_VIOLENT_ACT_PAST = (decapitated|poisoned|shot|killed|murdered|raped|(hurt <1.0>+$w<0.0>)|punched|stabbed|maimed|strangled|(beat up|(the $w03 out ?of)|($w03 to death)));
V_VULGARINSULT = (
	(you suck|stink)|(fuck you|off)|(i|we $w03 hate you)|(eat $w03 shit)|
	(suck|eat $w03 ?a dick|cock)|(lick my balls)|(eat $w03 bag ?of $V_CURSEWORD)|
	(blow me)|(piss off)
);
V_WEATHER_TYPES = ([rain?(y|(ing))]|[snow?(y|(ing))]|[hail?(ing)]|[wind?y]|sunny);
V_WHATS = what | what\'s | (what is) | (what was);
V_WHATSYOUROPINION = (
	((what are|were)|what\'re your ?$V_ACTUAL thoughts|opinions) |
	((what is|was)|what\'s your ?$V_ACTUAL opinion) |
	(what do|did you ?$V_ACTUALLY think) ?(of|about)
);
PERSON_NAME = (
	($GIVEN_NAME ?$LAST_NAME) |
	(<1.0>+$w<0.0>){% GivenName='' %}
);
GIVEN_NAME @= $factory:first_name {% GivenName = this._parsed %};
LAST_NAME @= $factory:last_name {% LastName = this._parsed %};
YEAR = ($factory:year);
DIGITS = ($factory:digits);
LOCATION_FACTORIES = (
	($factory:canada_city_province) |
	($factory:canada_province) |
	($factory:city_state) |
	($factory:country) |
	($factory:state) |
	($factory:world_city_country)
);
