### LOW PRIORITY KNOWN UNKNOWNS AND PARTIAL RECOGNITION ###


RULE_PR = (
	(sweetie|cutie|buddy|bud|(little guy) ~2) {% RecognizedPhrase='PetName' %} |
	(blah ?blah ?blah ~3) {% RecognizedPhrase='Blah' %} |
	(boo ~2) {% RecognizedPhrase='Boo' %} |
	((ha ha ?ha ?ha)|[haha?(ha)?(ha)] ~2) {% RecognizedPhrase='HaHa' %} |
	(oh my god ~7) {% RecognizedPhrase='OhMyGod' %} |
	(omg ~2) {% RecognizedPhrase='OMG' %} |
	(poop ~3) {% RecognizedPhrase='Poop' %} |
	(robot ~4) {% RecognizedPhrase='Robot' %} |
	(say what ~0) {% RecognizedPhrase='SayWhat' %} |
	(testing ?(one|1 two|2 three|3) ~6) {% RecognizedPhrase='Testing' %} |
	(($V_VULGARINSULT ~5)|($V_CURSEWORD ~2)|(what the $V_CURSEWORD ~6)|(get lost ~6)|(go away ~5)|(nobody|(no one) likes you)) {% RecognizedPhrase='VulgarInsult' %} |
	((do it ~0)|(just do it ~4)|(go for it ~4)) {% RecognizedPhrase='DoIt' %} |
	((nevermind ~8)|(forget it ~7)|(nothing ~6)|(nvm ~2)) {% RecognizedPhrase='Nevermind' %} |
	(sad ~2) {% RecognizedPhrase='Sad' %}
) {% intent='partialRecognition' %};
STRICT_RULE_PR = (
	((are you) ~0.1) {% RecognizedPhrase='AreYou' %} |
	((did you go) ~4) {% RecognizedPhrase='DidYouGo'%} |
	((please) ~5) {% RecognizedPhrase='Please' %}
) {% intent='partialRecognition' %};
RULE_KU_AreYouAbleTo = (
	(are you able|capable ?(of|to) <1.0>+$w<0.0>) |
	(do you know how ?to <1.0>+$w<0.0>) |
	(do you ever <1.0>+$w<0.0>) |
	(can you ?(do|(learn ?how ?to)) <1.0>+$w<0.0>) |
	($V_CAN_YOU <1.0>+$w<0.0>)
) {% intent= 'canJiboAction' %}{% priority='HIGH' %};
RULE_KU_AreYouAfraidOf = (
    (are you ?ever ?$V_VERY afraid|scared ?(of|about|by|around|(because ?of)) ?(a|an|the) <1.0>+$w<0.0>) |
    (do you ?ever feel|get ?$V_VERY afraid|scared ?(of|about|by|around|(because ?of)) ?(a|an|the) <1.0>+$w<0.0>) |
    (do|does ?the <1.0>+$w<0.0> ?$V_ACTUALLY scare you) |
	(do you think|believe ?the <1.0>+$w<0.0> ?(is|are) ?$V_ACTUALLY scary|frightening)
) {% intent= 'doesJiboFeelEmotionAboutThing' %} {% Emotion='Afraid' %};
RULE_KU_AreYouGoodAt = (
	(are you ?(any|$V_VERY) good|skilled ?at <1.0>+$w<0.0>)
) {% intent= 'isJiboSkilledAtThing' %}{% priority='HIGH' %};
RULE_KU_AreYouMy = (
	(are you my <1.0>+$w<0.0>)
) {% intent= 'isJiboUserRelation' %}{% priority='HIGH' %};
RULE_KU_AreYouSaying = (
	(are you saying|(trying to say) <1.0>+$w<0.0>) |
	(did|do you ?(actually|really) mean ?(to say) <1.0>+$w<0.0>) |
	(did you ?just say <1.0>+$w<0.0>)
) {% intent= 'requestClarifySpeech' %}{% priority='HIGH' %};
RULE_KU_CanISeeThing = (
	($V_CAN_USER|(let me) [see?(ing)] <1.0>+$w<0.0>)
) {% intent= 'canUserAction' %} {% Action='SeeThing' %};
RULE_KU_CanYouAccessThing = (
	($V_CAN_YOU|(do you have) [access?(ing)] <1.0>+$w<0.0>)
) {% intent= 'canJiboAction' %} {% Action='AccessThing' %};
RULE_KU_CanYouCleanThing = (
	($V_CAN_YOU [clean?(ing)]|[wash?(ing)] <1.0>+$w<0.0>)
) {% intent= 'canJiboAction' %} {% Action='Clean' %}{% priority='HIGH' %};
RULE_KU_CanYouGetUs = (
	($V_CAN_YOU [get?(ting)] us <1.0>+$w<0.0>)
) {% intent= 'canJiboAction' %} {% Action='RetrieveThing' %}{% priority='HIGH' %};
RULE_KU_CanYouGiveMe = (
	($V_CAN_YOU [giv(e|(ing))] me <1.0>+$w<0.0>)
) {% intent= 'canJiboAction' %} {% Action='GiveUserThing' %};
RULE_KU_CanYouMoveThing = (
	((are you able|capable ?(of|to))|(do you know how ?to)|(do you ever)|(can you) ?(do|(learn ?how ?to)) [mov(e|(ing))] <1.0>+$w<0.0>)
) {% intent='canJiboAction' %}{% Action='MoveThing'%};
RULE_KU_CanYouSeeThing = (
	($V_CAN_YOU [see?(ing)] <1.0>+$w<0.0>)
) {% intent= 'canJiboAction' %} {% Action='SeeThing' %};
RULE_KU_DidITellYou = (
	((did i ?ever tell you)|(have i ?ever told you) <1.0>+$w<0.0>)
) {% intent= 'didUserAction' %} {% Action='TellJiboThing' %} {% priority='HIGH' %};
RULE_KU_DidYouHearThing = (
	(did you hear <1.0>+$w<0.0>)
) {% intent= 'didJiboAction' %} {% Action='HearThing' %};
RULE_KU_DidYouKnowThat = (
	((did you know)|(were|are you aware) that <1.0>+$w<0.0>)
) {% intent= 'doesJiboKnowInformation' %};
RULE_KU_DoTheyLetYou = (
	(does your $w03 ?ever let|allow|permit you ?to <1.0>+$w<0.0>) |
	(are you ?ever allowed|permitted ?to <1.0>+$w<0.0>) |
	([do?(es)] they|$PERSON_NAME let you <1.0>+$w<0.0>)
) {% intent='isJiboAllowedToAction' %};
RULE_KU_DoYouCelebrateThing = (
	(do you celebrate <1.0>+$w<0.0>)
) {% intent= 'doesJiboCelebrateHoliday' %};
RULE_KU_DoYouFeelThing = (
	(do you feel <1.0>+$w<0.0>)
) {% intent= 'doesJiboFeelEmotion' %};
RULE_KU_DoYouHaveThing = (
	(do you have <1.0>+$w<0.0>)
) {% intent= 'doesJiboHaveThing' %};
RULE_KU_DoYouLike = (
	(do you like|love <1.0>+$w<0.0>)
) {% intent= 'doesJiboLikeThing' %};
RULE_KU_DoYouDislike = (
	(do you ?$V_ACTUALLY hate|dislike|despise|detest|(not like) <1.0>+$w<0.0>)
) {% intent= 'doesJiboDislikeThing' %};
RULE_KU_DoYouMissThing = (
	(do you miss <1.0>+$w<0.0>)
) {% intent= 'doesJiboMissThing' %};
RULE_KU_DoYouPrefer = (
	(do|would you prefer|(have a preference) <1.0>+$w<0.0>)
) {% intent= 'doesJiboHavePreferenceBetweenThings' %};
RULE_KU_DoYouWantThing = (
	((do you want)|(would you like) ?(a|an) <1.0>+$w<0.0>)
) {% intent= 'doesJiboWantThing' %};
RULE_KU_DoYouWantToGoTo = (
