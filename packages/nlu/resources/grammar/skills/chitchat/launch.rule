ENT_SHUFFLE_1 =
(
	((?$V_INTERESTING (black|(african american) history ?month [fact?s]|trivia))|(?(([some?(thing)] ?$V_INTERESTING)|(?$V_INTERESTING [fact?s]|trivia)) $w03 black|(african american) history ?month)) {% JiboContent='BlackHistoryMonthFact' %} |
    ((deep [thought?s])|(something ?$V_INTERESTING you\'ve|(you ?have) thought|(?been thinking) about)) {% JiboContent='DeepThought' %} |
    ((?$V_INTERESTING [fact?s])|(something $V_INTERESTING)) {% JiboContent='FunFact' %} |
    (?$V_INTERESTING health ?related [fact?s]|[tip?s]|advice) {% JiboContent='HealthTip' %} |
    ((?$V_INTERESTING [fact?s] about|[concern(s|(ing))]|(related ?to) people|([human?(s|(kind))] ?[being?s]))|([human?s] [fact?s])) {% JiboContent='HumanFact' %} |
