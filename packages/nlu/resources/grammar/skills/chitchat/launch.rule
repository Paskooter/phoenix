#Individual Entities

SS_AMPHIBIAN = ((
( [bullfrog?(s|(es)|(\'s))]) | ( [frog?(s|(es)|(\'s))]) |
( [newt?(s|(es)|(\'s))]) | (poison arrow  [frog?(s|(es)|(\'s))]) |
( [salamander?(s|(es)|(\'s))]) | ( [tadpole?(s|(es)|(\'s))]) |
( [toad?(s|(es)|(\'s))])
)~3) {% Amphibian='SomeAmphibian' %};

SS_BIRD = ((
( [bird?(s|(es)|(\'s))]) | ( [chick?(s|(es)|(\'s))]) |
( [crow?(s|(es)|(\'s))]) | ( [duck?(s|(es)|(\'s))]) |
( [duckling?(s|(es)|(\'s))]) | ( [eagle?(s|(es)|(\'s))]) |
( [goose?(s|(es)|(\'s))]) | ( [hawk?(s|(es)|(\'s))]) |
( [penguin?(s|(es)|(\'s))]) | ( [pigeon?(s|(es)|(\'s))]) |
( [seagull?(s|(es)|(\'s))]) | ( [swan?(s|(es)|(\'s))]) |
( [vulture?(s|(es)|(\'s))])
)~3) {% Bird='SomeBird' %};

