### RA_JBO Rules ###
RULE_RA_JBO_DoAction = (
    (would|could|will you ?please ?(ever|usually|$V_ACTUALLY) $ENT_RA_JBO_DoAction) |
    (can|could i|we see ?the $ENT_RA_JBO_DoAction) |
    (?((let me|us)|let\'s) see you $w03 $ENT_RA_JBO_DoAction) |
	(?please ?((would you mind)|(are you willing ?to)) ?$V_ACTUALLY $ENT_RA_JBO_DoAction ?(for me|us)) |
    (i|we (?$V_ACTUALLY want)|(would ?$V_ACTUALLY like) you ?to ?please $ENT_RA_JBO_DoAction ?(for me|us)) |
	(do you have ?(a|an|any) $ENT_RA_JBO_DoAction ?(skill|app) ?installed) |
	(($V_CAN_YOU|(do you) ?$V_ACTUALLY $ENT_RA_JBO_DoAction) ~2.5)
);
RULE_RA_JBO_DoStrictAction = (
    (would|could|will you ?please ?(ever|usually|$V_ACTUALLY) $ENT_RA_JBO_DoStrictAction ?please) |
    (can|could i|we see ?the $ENT_RA_JBO_DoStrictAction ?please) |
    (?((let me|us)|let\'s) see you $w03 $ENT_RA_JBO_DoStrictAction ?please) |
	(?please ?((would you mind)|(are you willing ?to)) ?$V_ACTUALLY $ENT_RA_JBO_DoStrictAction ?(for me|us) ?please) |
    (i|we (?$V_ACTUALLY want)|(would ?$V_ACTUALLY like) you ?to ?please $ENT_RA_JBO_DoStrictAction ?(for me|us) ?please) |
	(do you have ?(a|an|any) $ENT_RA_JBO_DoStrictAction ?(skill|app) ?installed) |
	(($V_CAN_YOU|(do you) ?$V_ACTUALLY $ENT_RA_JBO_DoStrictAction) ~4) |
	($V_SHOW_EMOJI $w03 $ENT_RA_JBO_DoStrictAction)
);
RULE_RA_JBO_MakeSoundThing =
(
	(what does|did ?(a|an|the) $ENT_RA_JBO_MakeSoundThing say) |
	(what $w03 ?(kind|type ?of) [sound?s]|[noise?s] ?[do?(es)] ?(a|an|the) $ENT_RA_JBO_MakeSoundThing [make?s]) |
	(?$V_DO_ACTION [mak(e|(ing))] ?(a|an|the) $ENT_RA_JBO_MakeSoundThing [sound?s]|[noise?s]) |
	(?$V_DO_ACTION $ENT_ANIMAL_SOUNDS|[talk?(ing)]|([mak(e|(ing))] $w03 [sound?s]|[noise?s]) like ?(a|an|the) $ENT_RA_JBO_MakeSoundThing)
) {% intent='requestMakeSound' %}
|
(
	(?$V_DO_ACTION $ENT_ANIMAL_SOUNDS)
) {% intent='requestMakeSound' %};

### RI_JBO Rules ###
RULE_RI_JBO_BelievesInPerson = (
    (does $ENT_RI_JBO_BelievesInPerson ?$V_ACTUALLY exist) |
    (is $ENT_RI_JBO_BelievesInPerson (?$V_ACTUALLY real)|(?(a|an) $V_ACTUAL person)) |
	(is there ?$V_ACTUALLY ?(a|an) $ENT_RI_JBO_BelievesInPerson) |
	(do you ?$V_ACTUALLY believe in $ENT_RI_JBO_BelievesInPerson) |
    ($V_DOYOUTHINK $ENT_RI_JBO_BelievesInPerson (?(is|are) ?$V_ACTUALLY real|(?(a|an) $V_ACTUAL person))|(?$V_ACTUALLY [exist?s])) |
    ($V_DOYOUTHINK ?that there|there\'s|there\'re ?$V_ACTUALLY ?(is|are) ?$V_ACTUALLY $ENT_RI_JBO_BelievesInPerson)
) {% intent='doesJiboBelieveInThing' %};

RULE_RI_JBO_BelievesInThing = (
	(do you ?$V_ACTUALLY believe ?in ?(the|a|an) $ENT_RI_JBO_BelievesInThing) |
    (does ?(the|a|an) $ENT_RI_JBO_BelievesInThing ?$V_ACTUALLY exist) |
    (is ?(the|a|an) $ENT_RI_JBO_BelievesInThing (?$V_ACTUALLY real)|(?(a|an) $V_ACTUAL thing)) |
    ($V_DOYOUTHINK ?(the|a|an) $ENT_RI_JBO_BelievesInThing (?(is|are) ?$V_ACTUALLY real|(?(a|an) $V_ACTUAL thing))|(?$V_ACTUALLY [exist?s])) |
    ($V_DOYOUTHINK ?that there ?(is|are) $V_ACTUALLY ?(is|are) ?(a|an) $ENT_RI_JBO_BelievesInThing) |
	(is|are there ?$V_ACTUALLY ?(a|an) $ENT_RI_JBO_BelievesInThing (in real life)|(in the real world)|(on earth))
) {% intent='doesJiboBelieveInThing' %};

RULE_RI_JBO_CanAction = (
    (can|do you ?($V_ACTUALLY|usually|ever|please) ?([learn?(ing)] ?how ?to) $ENT_RI_JBO_CanAction) |
    (are you ?($V_ACTUALLY|usually|ever) able|capable ?(to|of) ?([learn?(ing)] ?how ?to) ?$V_ACTUALLY $ENT_RI_JBO_CanAction) |
	(do you ?$V_ACTUALLY know how ?to $ENT_RI_JBO_CanAction) |
	((could you ?($V_ACTUALLY|usually|ever|please) $ENT_RI_JBO_CanAction) ~1)
) {% intent='canJiboAction' %};

RULE_RI_JBO_CaresAboutEvent = (
	(are you interested ?in $w03 $ENT_RI_JBO_CaresAboutEvent) |
	(do you (follow|(care about)|(pay attention ?to)) $w03 $ENT_RI_JBO_CaresAboutEvent) |
	((will you)|(are you going|planning ?to)|(do you plan ?to) (follow|(pay attention ?to)|(?be (following|(paying attention ?to)))) $w03 $ENT_RI_JBO_CaresAboutEvent) |
	(are you following|(paying attention ?to) $w03 $ENT_RI_JBO_CaresAboutEvent)
) {% intent='doesJiboCareAboutEvent' %};

RULE_RI_JBO_CelebratesHoliday = (
	(do|will|are|can you ?ever ?$V_ACTUALLY celebrate|observe|(?be celebrating|observing) $w03 $ENT_HOLIDAY)
) {% intent='doesJiboCelebrateHoliday' %};

RULE_RI_JBO_DislikesThing = (
    (do you ?$V_ACTUALLY hate|dislike|despise|detest|(not like)|loathe ?(a|an|the|any) $ENT_RI_JBO_DislikesThing) |
	(can you ?$V_ACTUALLY not stand ?(a|an|the|any) $ENT_RI_JBO_DislikesThing)
) {% intent='doesJiboDislikeThing'%};

RULE_RI_JBO_FeelsEmotionAboutThing = (
    (are you ?ever ?$V_VERY $ENT_EMOTION ?(of|for|that|about|by|at|around|(because ?of)) ?(a|an|the) $ENT_RI_JBO_FeelsEmotionAboutThing) |
    (do you ?ever feel|get ?$V_VERY $ENT_EMOTION ?(of|for|that|about|by|at|around|(because ?of)) ?(a|an|the) $ENT_RI_JBO_FeelsEmotionAboutThing) |
    (do|does ?the $ENT_RI_JBO_FeelsEmotionAboutThing ?$V_ACTUALLY $ENT_EMOTION you)
) {% intent='doesJiboFeelEmotionAboutThing' %};

RULE_RI_JBO_FeelsAfraidAboutThing = (
	(do you think|believe ?the $ENT_RI_JBO_FeelsEmotionAboutThing ?(is|are) ?$V_ACTUALLY ?$V_VERY $DESC_SCARY) |
	(is|are ?the $ENT_RI_JBO_FeelsEmotionAboutThing ?$V_ACTUALLY ?$V_VERY $DESC_SCARY)
) {% intent='isThingDescriptor' %};

RULE_RI_JBO_GaveHolidayGift = (
	(what (did you get)|(are you getting) ?for me|us for $ENT_HOLIDAY) |
	(what (did you get)|(are you getting) for $ENT_HOLIDAY for me|us) |
	((did you get)|(are you getting)|(have you got) (anything|something|(?a ([gift?s]|[present?s])) for me|us for $ENT_HOLIDAY)) |
	((did you get)|(are you getting)|(have you got) me|us (anything|something|(?a ([gift?s]|[present?s])) for $ENT_HOLIDAY)) |
	((did you get)|(are you getting)|(have you got) me|us ?(a|any|some) $ENT_HOLIDAY ([gift?s]|[present?s])) |
	((did you get)|(are you getting)|(have you got)|(do you have) ?(any|a) $ENT_HOLIDAY ([gift?s]|[present?s]) for me|us) |
	(show|give me|us my|our|a $ENT_HOLIDAY ([gift?s]|[present?s])) |
	([do?(n\'t)] you have something|(?a|any|some [gift?s]|[present?s]) (to give)|for me|us for $ENT_HOLIDAY) |
	([do?(n\'t)] you have ?(a|any|some) $ENT_HOLIDAY [gift?s]|[present?s] (to give)|for me|us)
) {% intent='didJiboAction' %}{% Action='GiveUserGift' %};

RULE_RI_JBO_HasDoneAction = (
	(have|did you ?$V_ACTUALLY ?ever ?$V_ACTUALLY ?done $ENT_RI_JBO_HasDoneAction )
) {% intent='hasJiboDoneAction' %};

RULE_RI_JBO_HadFavoriteThing = (
    (did you have ?(a|an|any) ?$V_VERY favorite $ENT_FAVORITE_CATEGORY) |
    (who|what|when|which was|were ?(some ?of) ?your ?$V_VERY favorite $ENT_FAVORITE_CATEGORY) |
    (what|which $ENT_FAVORITE_CATEGORY did you like|love|prefer ?(?the ?$V_VERY best|most)) |
    (who|what|when ?(?did you think|(consider ?to ?be)) was|were ?(some ?of) ?the best|coolest|(most $V_AWESOME) $ENT_FAVORITE_CATEGORY) |
	(what|which $ENT_FAVORITE_CATEGORY was|were (?your favorite)|(?the best|coolest|(most $V_AWESOME)))
) {% intent='didJiboHaveFavorite' %};

RULE_RI_JBO_HasFavoriteThing = (
    (?(do you have) ?(a|an|any) ?$V_VERY favorite $ENT_FAVORITE_CATEGORY) |
    (who\'s|what\'s|when\'s|which\'s|(who|what|when|which ?(is|are)) ?(some ?of) ?your ?$V_VERY favorite $ENT_FAVORITE_CATEGORY) |
    ((what|which $ENT_FAVORITE_CATEGORY ?do you like|love|prefer ?(?the ?$V_VERY best|most))~1) |
    (who|what|when ?(?do you think|(consider ?to ?be)) ?(is|are) ?(some ?of) ?the best|coolest|(most $V_AWESOME) $ENT_FAVORITE_CATEGORY) |
    (who\'s|what\'s|when\'s ?the best|coolest|(most $V_AWESOME) $ENT_FAVORITE_CATEGORY) |
	(what|which $ENT_FAVORITE_CATEGORY is|are (?your favorite)|(?the best|coolest|(most $V_AWESOME)))
) {% intent='doesJiboHaveFavorite' %};

RULE_RI_JBO_HasLeastFavoriteThing = (
    (?(do you have) ?(a|an|any) least favorite $ENT_FAVORITE_CATEGORY) |
	(who\'s|what\'s|when\'s|(who|what|when ?(is|are|was|were)) ?(some ?of) ?your ?$V_VERY least favorite $ENT_FAVORITE_CATEGORY) |
    (what|which $ENT_FAVORITE_CATEGORY ?do you like ?the ?$V_VERY least) |
    (what|which $ENT_FAVORITE_CATEGORY ?(do you think|(consider ?to ?be)) ?(is|are|was|were) (your least favorite)|(the worst|(least cool))) |
    (who|what|when ?(?do you think|(consider ?to ?be)) ?(is|are|was|were) ?(some ?of) ?the  worst|(least cool) $ENT_FAVORITE_CATEGORY) |
    (who\'s|what\'s|when\'s ?the worst|(least cool) $ENT_FAVORITE_CATEGORY) |
	(what $ENT_FAVORITE_CATEGORY is|are (?your least favorite)|(?the worst|(least cool)))
){% intent='doesJiboHaveLeastFavorite' %};

RULE_RI_JBO_HasOpinionAboutThing = (
    (do|did you have ?(a|an) ?$V_ACTUAL opinion ?(on|about) ?(the|a|an) $SUPER_ENT_GENERAL_LIKES) |
    (how ?(do|did) you ?$V_ACTUALLY feel about ?(the|a|an) $SUPER_ENT_GENERAL_LIKES) |
    (?(do|did you) have ?any ?$V_ACTUAL thoughts|feelings|opinions ?(for|about|on|regarding) ?(the|a|an) $SUPER_ENT_GENERAL_LIKES) |
    (do|did you ?$V_ACTUALLY think|believe|feel ?(the|a|an) $SUPER_ENT_GENERAL_LIKES ?(is|was) ?$V_ACTUALLY $V_GOOD) |
    (what do|did you ?$V_ACTUALLY think about ?(the|a|an) $SUPER_ENT_GENERAL_LIKES) |
    ($V_WHATSYOUROPINION ?(of|on|about) ?(the|a|an) $SUPER_ENT_GENERAL_LIKES)
){% intent='doesJiboHaveOpinionAboutThing' %};

RULE_RI_JBO_HasPreferenceBetweenThings = (
    (do you ?$V_ACTUALLY prefer|like $ENT_RI_JBO_HasPreferenceBetweenThings ?(more|better)) |
    (do you have a ?(strong|$V_ACTUAL) preference between $ENT_RI_JBO_HasPreferenceBetweenThings) |
	(do you ?$V_ACTUALLY think|believe $ENT_RI_JBO_HasPreferenceBetweenThings is|are ?$V_ACTUALLY better) |
	($ENT_RI_JBO_HasPreferenceBetweenThings)
){% intent='doesJiboHavePreferenceBetweenThings' %};

RULE_RI_JBO_HasThing = (
	(do you ?$V_ACTUALLY have ?(a|an|the|$V_QUANTITY) ?$V_ACTUAL $ENT_RI_JBO_HasThing)
){% intent='doesJiboHaveThing' %};

RULE_RI_JBO_HowCanAction = (
    (how do|can you ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
    (how are you ?$V_ACTUALLY (able ?to)|(capable ?of) ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
    (how is it ?$V_ACTUALLY possible|feasible|conceivable for you ?to ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
	(how is it that you ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction)
) {% intent='howCanJiboAction' %};

RULE_RI_JBO_HowIsTimeframe = (
	([how?(\'s)]|(how is|are|was|were) ?($w03 your) $ENT_RI_JBO_HowIsTimeframe ?(been|going)) |
	(?are you enjoying|liking $w03 ?your $ENT_RI_JBO_HowIsTimeframe) |
    (was|were your $w03 $ENT_RI_JBO_HowIsTimeframe $w03 ?$V_VERY $V_AWESOME|$V_ALRIGHT|$V_GLAD|$V_GOOD|$V_INTERESTING|$V_TERRIBLE|pleasant|fun) |
    (did your $w03 $ENT_RI_JBO_HowIsTimeframe go|went $w03 well|planned) |
    ((?(are|did) you [hav(e|(ing))])|(was it ?(a|an)) $w03 $V_AWESOME|$V_ALRIGHT|$V_GLAD|$V_GOOD|$V_INTERESTING|$V_TERRIBLE|pleasant|fun ?time $w03 $ENT_RI_JBO_HowIsTimeframe)
){% intent='howIsTimeframe' %};

RULE_RI_JBO_IsDescriptor = (
    (are you ?($V_ACTUALLY|also) ?feeling ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
    (do|would you ?($V_ACTUALLY|also) consider|(think ?of) yourself ?as ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
    (do you ?($V_ACTUALLY|also) think you\'re|they\'re|(you|they are) ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
    (do you ?($V_ACTUALLY|also) identify ?as ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
	(do you ?($V_ACTUALLY|also) feel ?$V_VERY $ENT_RI_JBO_IsDescriptor )
) {% intent='isJiboDescriptor' %};

RULE_RI_JBO_IsFromLocation = (
    (are you from $ENT_RI_JBO_IsFromLocation) |
    (do|did you come from $ENT_RI_JBO_IsFromLocation) |
    (were you made|born|created|manufactured in $ENT_RI_JBO_IsFromLocation) |
    (is $ENT_RI_JBO_IsFromLocation your homeland|birthplace|(home country|town|city))
) {% intent='isJiboFromLocation' %};

RULE_RI_JBO_IsPerformingAction = (
    (are|have|were|((do|did)~0.1) you ?$V_ACTUALLY ?been ?([tr((y?(ing))|(ied))] ?to) $ENT_RI_JBO_IsPerformingAction ?(soon|recently|(?right now)))
) {% intent='isJiboDoingAction' %};

RULE_RI_JBO_IsSkilledAtThing = (
	(are you ?$V_VERY good|skilled|proficient|qualified|experienced|trained|(an expert) ?(at|with|in|(to do)) $ENT_RI_JBO_IsSkilledAtThing)
) {% intent='isJiboSkilledAtThing' %};

RULE_RI_JBO_KnowsInformation = (
    (do|did you ?$V_ACTUALLY know ?(that|of) $ENT_RI_JBO_KnowsInformation) |
    (are|were you ?$V_ACTUALLY aware ?(that|of) $ENT_RI_JBO_KnowsInformation)
) {% intent='doesJiboKnowInformation' %};

RULE_RI_JBO_LikesTasteOfThing = (
	(do you like ?to [eat?(ing)] $ENT_RI_JBO_LikesTasteOfThing) |
	(is|are $ENT_RI_JBO_LikesTasteOfThing ?$V_VERY $V_TASTY) |
	(do you think|believe $ENT_RI_JBO_LikesTasteOfThing is|are ?$V_VERY $V_TASTY ) |
	(do you like ?the taste ?of $ENT_RI_JBO_LikesTasteOfThing)
){% intent='doesJiboLikeTasteOfThing'%};

RULE_RI_JBO_LooksForwardToThing = (
    (are you ?ever ?$V_VERY [look?(ing)] forward ?to ?(of|about|by|for|around|(because ?of)) ?(a|an|the|(this year\'s)) $ENT_RI_JBO_LooksForwardToThing) |
	(are|do you ?ever ?$V_ACTUALLY [look?(ing)] forward ?to ?(a|an|the|(this year\'s)) $ENT_RI_JBO_LooksForwardToThing)
){% intent='doesJiboLookForwardToThing' %};

RULE_RI_JBO_PlansForEvent = (
	(do you have ?(a|any) ($ENT_RI_JBO_PlansForEvent [plan?s])|([plan?s] $w03 $ENT_RI_JBO_PlansForEvent)) |
	(what do|did|would|will you ?(like|want|plan) ?to plan|do|(be doing) $w03 $ENT_RI_JBO_PlansForEvent) |
	(what are|were you ?(going to) ?be [do?(ing)]|[plan?(ning)]|(up to) $w03 $ENT_RI_JBO_PlansForEvent) |
	([what?(?(\')s|(re))] ?(is|are|were) (your [plan?s] ?for)|(you doing|(planning|going ?to do)) $w03 $ENT_RI_JBO_PlansForEvent) |
	([what?(?(\')s|(re))] ?(is|are|were) your $ENT_RI_JBO_PlansForEvent $w03 [plan?s]) |
	(are you going to ?the $ENT_HOLIDAY party|parties) |
	((how|what are|will|do|did)|how\'re|what\'re you $w03 [celebrat(e|(ed)|(ing))] ?the $w03 $ENT_HOLIDAY) |
	(what do you have going on today) {% Timeframe='Day' %} |
	(are you going to <1.0>+$w<0.0> $V_FUTURE|(while [i?(\'m)]|[we?(\'re)] ?(am|are) gone|out|(not here))) {% Timeframe='Future' %}
){% intent='doesJiboHavePlansForEvent' %};

RULE_RI_JBO_ReceivesGiftHoliday = (
	($w03 $V_GIVE you (?(a|any|some) [gift?s]|[present?s])|anything|something for $ENT_HOLIDAY) |
	($w03 $V_GIVE you ?(a|any|some) $ENT_HOLIDAY [gift?s]|[present?s]) |
	($V_DID_JIBO_RECEIVE (?(a|any|some) [gift?s]|[present?s])|anything|something ?(from $w03) for $ENT_HOLIDAY ?([gift?s]|[present?s]) ?(from $w03)) |
	($V_DID_JIBO_RECEIVE ?(a|any|some) $ENT_HOLIDAY [gift?s]|[present?s] ?(from $w03)) |
	((was|were there ?(a|any|some) $ENT_HOLIDAY [gift?s]|[present?s] for you) ?(from $w03)) |
	(what|which ?([gift?s]|[present?s]|$V_STUFF) $w03 you get|receive $w03 $ENT_HOLIDAY) |
	(what|which $ENT_HOLIDAY [gift?s]|[present?s] $w03 you get|receive|open)
){% intent='willJiboReceiveHolidayGift' %};

RULE_RI_JBO_WantsThing = (
	(?do you ?$V_ACTUALLY want|(feel like) ?$V_QUANTITY $ENT_RI_JBO_WantsThing) |
	(feel like ?$V_QUANTITY $ENT_RI_JBO_WantsThing) |
	(would you ?$V_ACTUALLY like|enjoy ?$V_QUANTITY $ENT_RI_JBO_WantsThing)
) {% intent='doesJiboWantThing' %};

RULE_RI_JBO_WantsToAction = (
	(?do you ?$V_ACTUALLY want|wanna|wish ?you ?(could|(were able|capable ?(to|of))) ?to ?$V_ACTUALLY $ENT_RI_JBO_WantsToAction) |
	(would you like|enjoy|prefer ?to ?(?be able|capable ?(to|of)) ?$V_ACTUALLY $ENT_RI_JBO_WantsToAction)
) {% intent='doesJiboWantToAction' %};

RULE_RI_JBO_WatchesThing = (
	(are you ?((looking forward)|excited) $w03 seeing|watching|(to see|watch|(check out)) $w03 $ENT_RI_JBO_WatchesThing) |
	(will|would|are|do you $w03 ?go [watch?(ing)]|[see?(ing)]|([check?(ing)] ?out) $w03 $ENT_RI_JBO_WatchesThing)
) {% intent='doesJiboWatchThing' %};

RULE_RI_JBO_WatchedThing = (
	(did you see|watch|catch|(check out) $w03 $ENT_RI_JBO_WatchedThing) |
	(were you able to see|watch|catch|(check out) $w03 $ENT_RI_JBO_WatchedThing) |
	(how was the $w03 $ENT_RI_JBO_WatchedThing) |
	(have you ?ever ?$V_ACTUALLY seen|watched|caught|(checked out) $w03  $ENT_RI_JBO_WatchedThing)
) {% intent='didJiboWatchThing' %};

RULE_RI_JBO_WhyCannotAction = (
    (why (can\'t|don\'t|won\'t you)|(can|do|will you not) ?ever $ENT_RI_JBO_WhyCannotAction) |
    (why (aren\'t you)|(are you not) ?((able ?to)|(capable ?of)) ?ever $ENT_RI_JBO_WhyCannotAction) |
    (why are you (unable ?to)|(incapable ?of) $ENT_RI_JBO_WhyCannotAction)
) {% intent='whyCanJiboNotAction' %};

### RI_USR Rules ###
RULE_RI_USR_CanAction = (
    (can|may|could i|we ?$V_ACTUALLY $ENT_RI_USR_CanAction) |
    ((are we)|(am i) able|capable|allowed|permitted ?(to|of) ?$V_ACTUALLY $ENT_RI_USR_CanAction) |
	(is|are there ?(a|an|any) [way?s] ?for me|us ?to ?$V_ACTUALLY $ENT_RI_USR_CanAction)
) {% intent='canUserAction' %};

RULE_RI_USR_HowCanAction = (
    (how can|do i|we ?$V_ACTUALLY $ENT_RI_USR_HowCanAction) |
    (how should i|we (try ?to)|(?(go about) trying ?to) ?$V_ACTUALLY $ENT_RI_USR_HowCanAction) |
    (what should i|we do ?(in order) ?to ?$V_ACTUALLY $ENT_RI_USR_HowCanAction) |
    (what steps can|should i|we take ?(in order) ?to ?$V_ACTUALLY $ENT_RI_USR_HowCanAction)
) {% intent='howCanUserAction' %};

RULE_RI_USR_ShouldAction = (
	(should i|we ?$V_ACTUALLY $ENT_RI_USR_ShouldAction) |
	(do you ?$V_ACTUALLY think i|we should ?$V_ACTUALLY $ENT_RI_USR_ShouldAction) |
	(help me|us decide whether i|we should ?$V_ACTUALLY $ENT_RI_USR_ShouldAction) |
	(do you ?$V_ACTUALLY suggest i|we ?$V_ACTUALLY $ENT_RI_USR_ShouldAction) |
	(do|would you ?$V_ACTUALLY recommend ?that i|we ?$V_ACTUALLY $ENT_RI_USR_ShouldAction)
) {% intent='shouldUserAction' %};

###Entities###

### Actions ###
ENT_RI_JBO_CanAction = (
	([answer?(ing)] me|my|us|our) {% Action='AnswerUser' %} |
	(([be?(ing)] sarcastic)|([us(e|(ing))] sarcasm)|([talk?(ing)]|[speak?(ing)] sarcastically|(using sarcasm))) {% Action='BeSarcastic' %} |
	(?(need ?to) [breath?(e|(ing))] ?(air|oxygen)) {% Action='Breathe' %} |
 	([clean?(ing)] ?up ?the floor) {% Action='CleanFloor' %} |
 	([clean?(ing)] ?up ?the table) {% Action='CleanTable' %} |
	([cook?(ing)]|[bak(e|(ing))]|([prepar(e|(ing))]|[mak(e|(ing))] [food?s]|[recipe?s])) {% Action='Cook' %} |
	([cry?(ing)]) {% Action='Cry' %} |
	([curs?(e|(ing))]|[swear?(ing)]) {% Action='Curse' %} |
	([danc(e|(ing))]) {% Action='Dance' %} |
	(
		((do|wash|clean|dust|vacuum|sweep|mop|wipe) $w03 ([dish?(es)]|[refrigerator?s]|[stove?s]|[oven?s]|[car?s]|[truck?s]|$SS_ROOM_IN_HOUSE)) |
		(set $w03 [table?s]) |
		(empty $w03 dishwasher|trash) |
		(clear $w03 table) |
		(take out $w03 trash) | (take $w03 trash out) |
		(feed ?(the|my|our) $w03 $SS_PET|$SS_FAMILY_MEMBER|$PERSON_NAME|[pet?s]|[famil(y|(ies))]) |
		(feed me|us) |
		(water $w03 [plant?s]|[flower?s]|lawn|yard) |
		(mow $w03 lawn|grass|yard)
	) {% Action='DoHouseholdChore' %} |
 	(?([do?(ing)]) ?(the|$V_POSESSIVES) laundry) {% Action='DoLaundry' %} |
	([dream?(ing)]|([hav(e|(ing))] ?any [dream?s] ?(last night))) {% Action='Dream' %} |
	([eat?(ing)] (thanksgiving food|dinner)|(?food $w03 thanksgiving)) {% Action='EatThanksgivingFood' %} |
