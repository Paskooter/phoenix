	$ENT_ROBOT_CHARACTER |
	(?$V_POSESSIVES $SS_FAMILY_MEMBER ?$PERSON_NAME) |
	(?$V_POSESSIVES $V_FRIEND ?$PERSON_NAME) {% Relation='Friend' %} |
	(?$V_POSESSIVES $V_ROMANTIC_PARTNER ?$PERSON_NAME) {% Relation='RomanticPartner' %} |
	(($PERSON_NAME)~4)
);

