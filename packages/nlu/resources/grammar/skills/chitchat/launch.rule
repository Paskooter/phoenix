!use_equivalent_words = true;
TopRule =
(
	( $* ?$KU_PREFIXES $D_GQA_LOW_PRIORITY $*) {% priority='LOW' %} |
	( $w03 ?$KU_PREFIXES $D_GQA_HIGH_PRIORITY $w03) {% priority='HIGH' %} |
	( $D_GQA_DEFLECTOR_PRIORITY_HIGH ) {% priority='HIGH' %} |
	( $* $D_GQA_DEFLECTOR_PRIORITY_LOW $*)  {% priority='LOW' %} |

	( $* $D_SR_MIXED_PRIORITY $*)  |
	( $w03 $D_SR_HIGH_PRIORITY_STRICT) {% priority='HIGH' %} |
	( $w03 $D_SR_HIGH_PRIORITY $w03) {% priority='HIGH' %} |
	( $* $D_SR_HIGH_PRIORITY_ENT_FORMAT $*) {% priority='HIGH' %}
);


### GENERAL QUESTION ANSWER DOMAIN ###

D_GQA_LOW_PRIORITY = ((
	($D_GQA_QUESTION_WORDS ?(are|is|was|were)) |
	(are|did|do|does|is|was|can) {% intent='generalQuestions'%} |
    (?(can you ~3) tell ?(me|us) ?about ) {% intent='generalQuestions'%} |
	(do you know <1.0>+$w<0.0>) {% intent='generalQuestions' %} |
	(look up <1.0>+$w<0.0>) {% intent='generalQuestions' %}
)~0.1);

D_GQA_DEFLECTOR_PRIORITY_HIGH = (
	(<1.0>?(?hey jibo)<0.0> $D_GQA_QUESTION_WORDS ?(are|is|was|were) ?(a|an|the)) |
	(<1.0>?(?hey jibo)<0.0> are|did|do|does|is|was|were|can ?(a|an|the))
) {% intent='idle' %};

D_GQA_DEFLECTOR_PRIORITY_LOW = ((
	(<0.1>(can your|i|my)<0.0>) |
	(<0.1>(are|did|do|got|was you|your|i|my)<0.0>) |
	(($D_GQA_QUESTION_WORDS ?$D_GQA_COMMON_VERBS you|your|i|my|[jibo?s])~2.5) |
    (<0.3>($D_GQA_COMMON_VERBS you|your|i|my|we|our|[jibo?s])<0.0>) |
    (<0.4>(you $D_GQA_COMMON_VERBS|like|made|need|said|see|sound|want <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(your $w03 $D_GQA_COMMON_VERBS <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(i|we|(my|our $w03) $D_GQA_COMMON_VERBS <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(i\'m|i\'ve|you\'re|you\'ve|we\'re|we\'ve|let\'s <1.0>+$w<0.0>)<0.0>)
)~2) {% intent='idle' %};

D_GQA_QUESTION_WORDS = (
	([how?((?(\')s)|(?(\')re))]) {% intent='generalHowQuestions' %} |
	([what?((?(\')s)|(?(\')re))]) {% intent='generalWhatQuestions' %} |
	([when?((?(\')s)|(?(\')re))]) {% intent='generalWhenQuestions' %} |
	([where?((?(\')s)|(?(\')re))]) {% intent='generalWhereQuestions' %} |
	([which?((?(\')s)|(?(\')re))]) {% intent='generalWhichQuestions' %} |
	([who?((?(\')s)|(?(\')re))]) {% intent='generalWhoQuestions' %} |
	([why?((?(\')s)|(?(\')re))]) {% intent='generalWhyQuestions' %}
);

D_GQA_COMMON_VERBS = (
	ain\'t|am|[are?(n\'t)]|[can?(n\'t)]|[could?(n\'t)]|[did?(n\'t)]|
    [do?(es)?(n\'t)]|got|[ha(s|(ve))?(n\'t)]|[is?(n\'t)]|[should?(n\'t)]|
    [was?(n\'t)]|[were?(n\'t)]|will|[would?(n\'t)]|won\'t
);

D_GQA_HIGH_PRIORITY = (
	($RULE_RequestWeather) |
	(?(tell ?(me|us)) (
		(define <1.0>+$w<0.0>) {% intent='generalQuestions' %} |
		(?(can you) ?please spell <1.0>+$w<0.0> ?(for me)) {% intent='generalQuestions' %} |
		(did|are|is|will the <1.0>+$w<0.0> win|lose|play) {% intent='generalQuestions' %} |
		([add?((ing)|(ed))]|[subtract?((ing)|(ed))]|[multipl(y|(ing)|(ed))]|[divid(e|(ing)|(ed))] $* $V_NUMBER) {% intent='generalQuestions' %} |
		($V_NUMBER $w03 plus|minus|divided|multiplied|times $w03 $V_NUMBER) {% intent='generalQuestions' %} |
		(how ?((do|would|should you|i)|(does one)) $* spell <1.0>+$w<0.0>) {% intent='generalHowQuestions' %} |
		($V_WHATS ?the $* score) {% intent='generalWhatQuestions' %} |
		([what?(?(\')s)] ?is ?the definition ?of <1.0>+$w<0.0>) {% intent='generalWhatQuestions' %} |
		([what?(\'s)] ?is ?the volume of a|an|the <1.0>+$w<0.0> ) {% intent='generalWhatQuestions' %} |
		([what?(\'s)] ?is ?the volume ?of $w03 $SS_SHAPE) {% intent='generalWhatQuestions' %} |
		(([what?(\'s)] (?is ?the date)|(day|date ?is) $w03 $V_FUTURETIMES|$V_RECENT_PAST) ~3) {% intent='generalWhatQuestions' %} |
		(what won|recieved|(was nominated)|medaled $* [award?s]|[prize?s]|[nomination?s]|[championship?s]|$V_AWARDNAMES) {% intent='generalWhatQuestions' %} |
		(when|(what $w03 time ?is)|(time $w03 ?when) $* sunrise|sunset|(sun $w03 [set?(ting)]|[ris(e|(ing))])) {% intent='generalWhenQuestions' %} |
		(what [time?s] ?($w03 is|are|will) $* (?$V_SPORTS $V_SPORTSGAME)|$V_SPORTS|([play?(s|(ing))] $w03 ?$V_SPORTS)) {% intent='generalWhenQuestions' %} |
		(when|what ?was $* release date) {% intent='generalWhenQuestions' %} |
		(when is the u.s.|us|british|australian open) {% intent='generalWhenQuestions' %} |
		((?(do you know) ([when?(?(\')s)] ?((will it)|(is it)))|([what?(?(\')s)]|which $w03 day|date)|(how long ?until) $w03 (independence day $w03 $factory:country)|($SS_NATIONALITY independence day)) ~1) {% intent='generalWhenQuestions' %} |
		((is|will (independence day $w03 $factory:country)|($SS_NATIONALITY independence day) ?be $V_FUTURETIMES) ~1) {% intent='generalWhenQuestions' %} |
		((who)|(what person|[band?s]) sang|sings ?(?the song) <1.0>+$w<0.0>) {% intent='generalWhoQuestions' %} |
	    (who|(what person) [direct?(s|(ed))] ?(?the movie) <1.0>+$w<0.0>) {% intent='generalWhoQuestions' %} |
	    (who|(what person) wrote ?(?the movie|book|script|show|song|poem) <1.0>+$w<0.0>) {% intent='generalWhoQuestions' %} |
	    (who|(what person) [perform?(s|(ed))] $* ?(?in ?the movie|play|show|song) <1.0>+$w<0.0>) {% intent='generalWhoQuestions' %} |
	    (who|(what person) [star?(s|(red))] ?in $* ?(?the movie|play|show|song) <1.0>+$w<0.0>) {% intent='generalWhoQuestions' %} |
		(who won|lost|played $* $V_SPORTSGAME ) {% intent='generalWhoQuestions' %} |
		(who won|recieved|(was nominated)|medaled $* [award?s]|[prize?s]|[nomination?s]|[championship?s]|$V_AWARDNAMES) {% intent='generalWhoQuestions' %} |
		([who?(\'s)] ?(is|was) $w03 best actor|actress $w03 $YEAR) {% intent='generalWhoQuestions' %}
	))
);

RULE_RequestWeather = (
	(will (it ?be)|(there be ?any) $V_WEATHER_TYPES ?$V_FUTURETIMES) |
	(is it ?(gonna|(going ?to)) ?be $V_WEATHER_TYPES ?$V_FUTURETIMES) |
	([what?(\'s)] [today?(\'s)] temperature|humidity) |
	(do|will i|we want|need $w03 [umbrella?s]) |
	(should i|we grab|bring|take $w03 [umbrella?s]) |

	((weather|(?weather forecast) ?$V_SPECIFY_TIME ?$V_IN_LOCATION ?$V_SPECIFY_TIME)~3) |
    (($V_CHECK $w03 ?([today?(\'s)]|[tomorrow?(\'s)]) weather|(?weather forecast) ?$V_IN_LOCATION)~3) |
	($V_CHECK $w03 $LOCATION_FACTORIES $w03 ?([today?(\'s)]|[tomorrow?(\'s)]) weather|(?weather forecast)) |
    (([what?(?(\')s|(ll))]|[how?(?(\')s|(ll))] ?(is|will) $w03 weather|(?weather forecast) ?(be|[look?(ing)]) ?$V_SPECIFY_TIME ?$V_IN_LOCATION ?$V_SPECIFY_TIME)~3) |
	([what?(?(\')s|(ll))]|[how?(?(\')s|(ll))] ?(is|will) $w03 $LOCATION_FACTORIES $w03 weather|(?weather forecast) ?(be|[look?(ing)]) ?$V_SPECIFY_TIME) |
    (([what?(?(\')s|(ll))] ?(is|will) [today?(\'s)]|[tomorrow?(\'s)] weather|(?weather forecast) ?(be|[look?(ing)] like) ?$V_IN_LOCATION)~3)
) {% intent='requestWeather'%};

KU_PREFIXES = (
    (i (was ?$V_ACTUALLY saying|(trying to say))|(meant to say) $w03) |
	($V_CAN_YOU ?$V_ACTUALLY $w03) |
    ($V_CAN_YOU ?$V_ACTUALLY access $w03) |
    ($V_CAN_YOU ?$V_ACTUALLY get ?(me|us) [info?(rmation)] $w03) |
    ($V_CAN_YOU ?$V_ACTUALLY give ?(me|us) [info?(rmation)] $w03) |
    (do you ?$V_ACTUALLY have [info?(rmation)] $w03) |
    ((i ?$V_ACTUALLY want)|(i\'d|(i would) ?$V_ACTUALLY like) ?to know|(hear about) $w03) |
    (i ?$V_ACTUALLY wish ?to know|(hear about) $w03) |
    (i ?$V_ACTUALLY wish you $w03 tell $w03)
~0.1);

