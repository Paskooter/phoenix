    (?(my|our) [fortune?s]) {% JiboContent='Fortune' %} |
    ([haiku?s]) {% JiboContent='Haiku' %} |
    (?(one of) ?your [dream?s]) {% JiboContent='Dream' %} |
    (((sci fi)|(science fiction) [quote?s])|([quote?s] about|from|[concern(s|(ing))] (sci fi)|(science fiction))) {% JiboContent='ScifiQuote' %} |
    (weird|funny [word?s]) {% JiboContent='WeirdWord' %} |
    ((words ?of wisdom)|(wise words)|(weird|random|dubious advice)) {% JiboContent='WordsOfWisdom' %}
);

ENT_SHUFFLE_2 = 	#Shuffle 2 contains entities with GQA definitions that shouldn't match What is a ENTITY
(
	([haiku?s]) {% JiboContent='Haiku' %} |
