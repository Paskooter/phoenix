		(?(when [it?(?(\')s)] ?(is|was)) ?the (spring ?(time|season))|(springtime)|(season ?of spring)){% Holiday='SeasonSpring' %} |
		(?(when [it?(?(\')s)] ?(is|was)) ?the (summer ?(time|season))|(summertime)|(season ?of summer)){% Holiday='SeasonSummer' %} |
		(?(when [it?(?(\')s)] ?(is|was)) ?the (winter ?(time|season))|(wintertime)|(season ?of winter)){% Holiday='SeasonWinter' %} |
