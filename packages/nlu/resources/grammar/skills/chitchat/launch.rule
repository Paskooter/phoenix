#### Entity Format ###


RULE_CanJiboBeDescriptor = (
    (can you ?($V_ACTUALLY|usually|ever) [get?(ting)]|[be?(ing)]|[becom(e|(ing))]|[feel?(ing)] ?$V_VERY $ENT_GENERAL_DESCRIPTOR|$ENT_EMOTION) |
	(do|have you (?($V_ACTUALLY|usually|ever) get|gotten)|(usually|ever get|gotten|[be?(en)]|become|feel|felt) ?$V_VERY $ENT_GENERAL_DESCRIPTOR|$ENT_EMOTION) |
	(are you ?($V_ACTUALLY|usually|ever) able|capable ?(to|of)  ?$V_ACTUALLY [get?(ting)]|[be?(ing)]|[becom(e|(ing))]|[feel?(ing)] ?$V_VERY $ENT_GENERAL_DESCRIPTOR|$ENT_EMOTION) |
	(could you ?($V_ACTUALLY|usually|ever) [get?(ting)]|[be?(ing)]|[becom(e|(ing))]|[feel?(ing)] ?$V_VERY $ENT_GENERAL_DESCRIPTOR|$ENT_EMOTION)
) {% intent='canJiboBeDescriptor' %};

RULE_DidJiboLikeThing = (
	(did you ?$V_ACTUALLY like|love|adore|enjoy ?(a|an|the) ?$V_VERY $SUPER_ENT_GENERAL_LIKES)
) {% intent='didJiboLikeThing' %};

RULE_DidJiboObserveThing = (
	(did ?(a|an|the|$V_QUANTITY) $ENT_DidJiboObserveThing ?$V_ACTUALLY come|visit)|
	(did|have you ?ever ?$V_ACTUALLY [see?n]|[observe?d] ?(a|an|the|$V_QUANTITY) $ENT_DidJiboObserveThing)
){% intent='didJiboObserveThing'%};

ENT_DidJiboObserveThing = (
	$ENT_FANTASTIC_PERSON |
	$SS_FANTASY_CREATURE
);

RULE_DoesJiboKnowPersonThing = (
	(?do you know ?about $ENT_DoesJiboKnowPersonThing) |
	(?do you and $ENT_DoesJiboKnowPersonThing know each other) |
	(do you know who|what $ENT_DoesJiboKnowPersonThing is|are) |
	(have you heard of|about $ENT_DoesJiboKnowPersonThing) |
	(are you familiar with $ENT_DoesJiboKnowPersonThing|(who|what $ENT_DoesJiboKnowPersonThing is))
){% intent='doesJiboKnowPersonThing' %};

ENT_DoesJiboKnowPersonThing = (
	$SUPER_ENT_PERSON |
	(?the ?$ENT_HOLIDAY ?song $ENT_SONG ?song)
);

RULE_DoesJiboLikeThing = (
    (do you ?$V_ACTUALLY like|love|adore|enjoy ?(a|an|the) ?$V_VERY $SUPER_ENT_GENERAL_LIKES)
) {% intent='doesJiboLikeThing' %};

RULE_DoesJiboWantToBeDescriptor = (
    ((do you ?$V_ACTUALLY want|wish)|(would you ?$V_ACTUALLY like) ?to be ?(seen ?as) ?(a|an|the) ?$V_VERY $ENT_DoesJiboWantToBeDescriptor) |
    ((do you ?$V_ACTUALLY want|wish)|(would you ?$V_ACTUALLY like) ?for people to ?$V_ACTUALLY (see|(think ?of)|consider you ?as)|(think|believe you are) ?(a|an|the) ?$V_VERY $ENT_DoesJiboWantToBeDescriptor) |
    (do you ?$V_ACTUALLY wish you were|(could be) ?(a|an|the) ?$V_VERY $ENT_DoesJiboWantToBeDescriptor)
){% intent='doesJiboWantToBeDescriptor' %};

ENT_DoesJiboWantToBeDescriptor = (
	(person|human) {% GeneralDescriptor='Person' %}
);

RULE_DoesJiboWearThing = (
	(do you wear $ENT_RI_JBO_WearsThing)
) {% intent='doesJiboWearThing' %};

RULE_HasJiboMetPerson = (
	((have|did you [me?et])|(have i introduced) $w03 $SUPER_ENT_PERSON) |
	(have|did you and $SUPER_ENT_PERSON [me?et] ?(each other))
){% intent='hasJiboMetPerson' %};

RULE_IsJiboFriendsWithPerson = (
	(are you ?(even|also) ?$V_ACTUALLY friends with $SUPER_ENT_PERSON) |
