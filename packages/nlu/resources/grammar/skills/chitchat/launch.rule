ENT_EMOTION = (
	($EMOTION_AFRAID) |
	($EMOTION_AMUSED) |
	($EMOTION_ANGRY) |
	($EMOTION_ANNOYED) |
	($EMOTION_ANXIOUS) |
	($EMOTION_CONFIDENT) |
	($EMOTION_CONFUSED) |
	($EMOTION_EMBARRASSED) |
	($EMOTION_EXCITED) |
	($EMOTION_HAPPY) |
	($EMOTION_JEALOUS) |
	($EMOTION_LONELY) |
	($EMOTION_PROUD) |
	($EMOTION_SAD)
);
EMOTION_AFRAID = (
	(afraid) | ([bug(g(ed)|(ing))] out) | (fearful) |
	([freak?((ed)|(ing)|s)] out) | ([frighten?(s|(ed))]) | ([scare?(s|d)]) |
	([spook?(s|(ed))]) | ([terrif(y|(ied)|(ies))])
) {% Emotion='Afraid' %};
EMOTION_AMUSED = (
	(amused) | (entertained) | (giggly)
) {% Emotion='Amused' %};
EMOTION_ANGRY = (
	(angry) | (bitter) | (enraged) | (fuming) | (furious) | (incensed) |
	(infuriated) | (irate) | (mad) | (offended) | (outraged)
) {% Emotion='Angry' %};
EMOTION_ANNOYED = (
	(aggravated) | (annoyed) | (cranky) | (frustrated) | (grumpy) | (irked) |
	(irritable) | (irritated) | (perturbed) | (sulking) | (sulky) | (testy)
) {% Emotion='Annoyed' %};
EMOTION_ANXIOUS = (
	(?a wreck) | (agitated) | (antsy) | (anxious) | (concerned) |
	(disturbed) | (edgy) | (fidgety) | (high-strung) | (jumpy) | (nervous) |
	(neurotic) | (restless) | (stressed) | (tense) | (uncomfortable) |
	(uneasy) | (uptight) | (worried)
) {% Emotion='Anxious' %};
EMOTION_CONFIDENT = (
	(confident) | (secure) | (self-assured) | (self-confident)
) {% Emotion='Confident' %};
EMOTION_CONFUSED = (
	(at ?a loss) | (baffled) | (bewildered) | (clueless) | (confused) |
	(flustered) | (lost) | (mixed up) | (perplexed) | (puzzled) | (stumped) |
	(thrown off) | (uncertain) | (unclear) | (unsure)
) {% Emotion='Confused' %};
EMOTION_EMBARRASSED = (
	(apologetic) | (ashamed) | (blushing) | (embarrassed) | (humbled) |
	(humiliated) | (insecure) | (mortified) | (regretful) | (remorseful) |
	(self-conscious) | (shamed) | (sheepish)
) {% Emotion='Embarrassed' %};
EMOTION_EXCITED = (
	(excited) | (psyched) | (jazzed) | (pumped)
) {% Emotion='Excited' %};
EMOTION_HAPPY = (
	(carefree) | (cheerful) | (chipper) | (content) | (delighted) |
	(ecstatic) | (elated) | (enthusiastic) | (giddy) | (glad) |
	(happy) | (inspired) | (jolly) | (jovial) | (joyful) | (joyous) |
	(on cloud nine) | (overjoyed) | (perky) | (pleased) | (thrilled) |
	(upbeat)
) {% Emotion='Happy' %};
EMOTION_JEALOUS = (
	(envious) | (jealous) | (possessive)
) {% Emotion='Jealous' %};
EMOTION_LONELY = (
	(alone) | (lonely) | (lonesome)
) {% Emotion='Lonely' %};
EMOTION_PROUD = (
	(honored) | (proud)
) {% Emotion='Proud' %};
EMOTION_SAD = (
	(brokenhearted) | (bummed out) | (bummed) | (dejected) | (depressed) |
	(desperate) | (devastated) | (disappointed) | (distressed) | (downcast) |
	(downhearted) | (feeling blue) | (feeling down) | (gloomy) |
	(heartbroken) | (heartsick) | (?in ?a bad mood) | (in ?a funk) |
	(miserable) | (moody) | (mournful) | (out of sorts) | (sad) | (somber) |
	(sorrowful) | (sullen) | (troubled) | (unhappy) | (upset)
) {% Emotion='Sad' %};

