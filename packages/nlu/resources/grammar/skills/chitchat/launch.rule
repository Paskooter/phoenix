		([ide?s] ?of march) {% Holiday='IdesOfMarch' %} |
		(?[?(inter)national] [wom(e|a)n?(?(\')s)] day) {% Holiday='InternationalWomensDay' %} |
		(labor day) {% Holiday='LaborDay' %} |
		(lgbt|(gay ?(and lesbian)) pride ?month) {% Holiday='LGBTPrideMonth' %} |
		(mardi [gra?s]) {% Holiday='MardiGras' %} |
		(mlk|(martin luther [king?(s|(\'s))]) day|weekend) {% Holiday='MartinLutherKingDay' %} |
		(memorial day|weekend) {% Holiday='MemorialDay' %} |
		([mother?(?(\')s?(\'))] day) {% Holiday='MothersDay' %} |
