### VOCABULARY ###
SETUP = setup | ( set up ) | install;
LIGHT = ( ?( $PHILIPS | $HUE | ($PHILIPS $HUE ) )
            ( [light?(?(\')s)]) | [lamp?(?(\')s)]) | [lightbulb?(?(\')s)];
PHILIPS = philips | phillips | philip\'s | phillip\'s;
HUE = hue | hugh | hew;
SWITCH = turn | switch;
ADJUST = adjust | dial | change;
DARKER = lower | dimmer | darker | down | back | (less bright);
HIGHER = higher | brighter | up;
DIM = dim | darken;
BRIGHTEN = brighten | (turn up) | increase;
WARMER =  warmer | hotter | cozier;
COOLER =  cooler | colder;
TEACH = teach | tell | instruct;
MEUS = me | us;
USE = use | operate;
LESSON = lesson | tutorial | instructional;
FORGET = forget | delete;
CHANGE = change | [?(re)set] | pick | select | modify;
ROOM = room | group;
OTHER = different | another | other;
MAKE = $SWITCH | make | set;
