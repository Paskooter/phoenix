### VOLUME ###

D_GLOBALS_INTENT_VOLUMEMAX =
	(((turn | crank) $D_GLOBALS_V_THEVOLUME ?(all the) way up)|
	((turn | crank) up $D_GLOBALS_V_THEVOLUME all the way)|
	((max | maximum) ?volume)) {_intent='volumeToValue'} {_volumeLevel='10'}
;


D_GLOBALS_INTENT_VOLUMEMIN =
	((turn $D_GLOBALS_V_THEVOLUME ?(all the) way down ) |
	(turn down $D_GLOBALS_V_THEVOLUME all the way)|
	((min | minimum) ?volume)) {_intent='volumeToValue'} {_volumeLevel='01'}
;

D_GLOBALS_INTENT_STRICT_VOLUMEUP = (
	(too soft|quiet) |
	(?(?a little ?bit ?more) louder)
) {_intent='volumeUp'}
;

D_GLOBALS_INTENT_VOLUMEUP = (
	( ?(turn|crank) $D_GLOBALS_V_THEVOLUME up ?(?some more)) |
	(increase $D_GLOBALS_V_THEVOLUME ?(?some more)) |
	((turn|crank) up $D_GLOBALS_V_THEVOLUME ) |
    (make|turn $D_GLOBALS_V_THEVOLUME ?up louder|higher) |
    (make|turn it|this|that ?up louder) |
	((i|we can\'t|(can not)|cannot) hear you) |
	(play|sing|speak|talk|be|get|make ?(it|that) ?((?a (little ?bit)|(bit) ?more)|any) louder) |
	(not so|too|that quiet|soft) |
	(speak up) |
	(you $w03 louder) |
	(your|you|you\'re $w03 too soft|quiet)
)  {_intent='volumeUp'}
;

D_GLOBALS_INTENT_STRICT_VOLUMEDOWN = (
	(too loud) |
	(?(?a little ?bit ?more) softer|quieter)
) {_intent='volumeDown'}
;

D_GLOBALS_INTENT_VOLUMEDOWN = (
	(?turn $D_GLOBALS_V_THEVOLUME down ?(?some more) ) |
	(decrease $D_GLOBALS_V_THEVOLUME ?(?some more)) |
	((turn ?it down)|lower $D_GLOBALS_V_THEVOLUME) |
    (make|turn $D_GLOBALS_V_THEVOLUME quieter|softer|lower) |
	(not so|too|that loud) |
	(your|you|you\'re $w03 too loud) |
	(you $w03 softer|quieter) |
    (play|sing|speak|talk|be|get|make ?(it|that) ?((?a (little ?bit)|(bit) ?more)|any) quieter|softer)
) {_intent='volumeDown'}
;

D_GLOBALS_INTENT_VOLUMETOVALUE =
	((turn|crank|increase|decrease $D_GLOBALS_V_THEVOLUME ?(up | down) ?$D_GLOBALS_V_TO ?(volume | level | (volume level)) $D_GLOBALS_V_VALUE)|
	(turn|crank|lower ?(up | down) $D_GLOBALS_V_THEVOLUME ?$D_GLOBALS_V_TO ?(volume | level | (volume level)) $D_GLOBALS_V_VALUE)|
	(?set $D_GLOBALS_V_THEVOLUME ?(at|$D_GLOBALS_V_TO) ?(volume | level | (volume level)) $D_GLOBALS_V_VALUE ) |
	(change $D_GLOBALS_V_THEVOLUME ?$D_GLOBALS_V_TO ?(volume | level | (volume level)) $D_GLOBALS_V_VALUE) |
	( ?make (the | your) (volume | level | (volume level)) $D_GLOBALS_V_VALUE )) {_intent='volumeToValue'} {_volumeLevel=D_GLOBALS_V_VALUE._value}
;


### USEFUL VOCABULARY ###
# LOOPMEMBER = $handle:crew{_loopmember = crew._users};
# OTHER_LOOPMEMBER = $handle:crew{_loopmember = crew._users};
D_GLOBALS_V_GOTO = (go ?back to) | (return to) | (bring up) | (bring (me | us) to) | load | access | ( show ?(me | us)) | display;
D_GLOBALS_V_THEVOLUME = (?(the | your) volume|radio|music|voice);
D_GLOBALS_V_PRONOUNS = my|her|his|their;
D_GLOBALS_V_TO = (to|two|too|2);
D_GLOBALS_V_VALUE =
	(
		( (zero|0|20|(2 0)) {_value='0'} ) |
		( (one|1|21|(2 1)) {_value='01'} ) |
		( (two|2|22|(2 2)|tutu) {_value='02'} ) |
		( (three|3|23|(2 3)) {_value='03'} ) |
		( (four|4|24|(2 4)) {_value='04'} ) |
		( (five|5|25|(2 5)) {_value='05'} ) |
		( (six|6|26|(2 6)) {_value='06'} ) |
		( (seven|7|27|(2 7)) {_value='07'} ) |
		( (eight|8|28|(2 8)) {_value='08'} ) |
		( (nine|9|29|(2 9)) {_value='09'} ) |
		( (ten|10|210|(2 10)) {_value='10'})
    );
D_GLOBALS_V_OTHER_PLACE = (
    ([((some)|(any))((place)|(where))]|(some|any place|where) else)|
    (?(at|in|[toward?s]) another|(?(the|any|some|a|an) other|alternante|different) direction|way|location|area)
);
D_GLOBALS_V_LOOK = (
    [look?(ing)]|[star(e|(ing))]|[peek?(ing)]|[gaz(e|(ing))]|[ogl(e|(ing))]|
    [scrutiniz(e|(ing))]|[watch?(ing)]|[gap(e|(ing))]|[observ(e|(ing))]
);
SKILL_NAMES = skill | app | gallery | create | clock | [setting?s] | photobooth | [photo?s] | (circuit saver) | tutorial | (bot [basic?s]) | (?$V_JIBO music|radio);
V_JIBO = ([jibo?(?(\')s)] | [geebo?(?(\')s)] | [gebo?(?(\')s)] | [jebo?(?(\')s)] | [cibo?(?(\')s)] | jb | g | kgb | diva);
