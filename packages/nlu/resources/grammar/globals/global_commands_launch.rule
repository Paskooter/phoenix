TopRule = (
	($w03
		(
			$D_GLOBALS {intent=D_GLOBALS._intent}
		) | (
			$D_GLOBALS_VOLUME {intent=D_GLOBALS_VOLUME._intent}
			{volumeLevel=D_GLOBALS_VOLUME._volumeLevel}
		)
		# | (
		# 	$D_GLOBALS_WRONGNAME {intent=D_GLOBALS_WRONGNAME._intent}
		# 		{realName=D_GLOBALS_WRONGNAME._realName}
		# )
	$w03) | (
		$D_GLOBALS_STRICT_VOLUME {intent=D_GLOBALS_STRICT_VOLUME._intent}
			{volumeLevel=D_GLOBALS_STRICT_VOLUME._volumeLevel}
	)
){domain='global_commands'}{priority='HIGH'}
;


### GLOBAL COMMANDS DOMAIN ###
D_GLOBALS =
(
# 	$D_GLOBALS_INTENT_MAINMENU {_intent=D_GLOBALS_INTENT_MAINMENU._intent}
# ) | (
#	$D_GLOBALS_INTENT_WHATCANIDO {_intent=D_GLOBALS_INTENT_WHATCANIDO._intent}
# ) | (
# 	$D_GLOBALS_INTENT_HELP {_intent=D_GLOBALS_INTENT_HELP._intent}
# ) | (
	$D_GLOBALS_INTENT_STOP {_intent=D_GLOBALS_INTENT_STOP._intent}
) | (
	$D_GLOBALS_INTENT_SLEEP {_intent=D_GLOBALS_INTENT_SLEEP._intent}
) | (
	$D_GLOBALS_INTENT_OVERHERE {_intent=D_GLOBALS_INTENT_OVERHERE._intent}
) | (
	$D_GLOBALS_INTENT_TURN_AWAY {_intent=D_GLOBALS_INTENT_TURN_AWAY._intent}
) | (
	$D_GLOBALS_INTENT_TURN_AROUND {_intent=D_GLOBALS_INTENT_TURN_AROUND._intent}
)
# | (
# 	$D_GLOBALS_INTENT_HOLDON {_intent=D_GLOBALS_INTENT_HOLDON._intent}
# )
;

D_GLOBALS_STRICT_VOLUME =
(
	$D_GLOBALS_INTENT_STRICT_VOLUMEUP {_intent=D_GLOBALS_INTENT_STRICT_VOLUMEUP._intent} {_volumeLevel='null'}
)|
(
	$D_GLOBALS_INTENT_STRICT_VOLUMEDOWN {_intent=D_GLOBALS_INTENT_STRICT_VOLUMEDOWN._intent} {_volumeLevel='null'}
)
;

D_GLOBALS_VOLUME =
(
	$D_GLOBALS_INTENT_VOLUMEMAX {_intent=D_GLOBALS_INTENT_VOLUMEMAX._intent}
							{_volumeLevel=D_GLOBALS_INTENT_VOLUMEMAX._volumeLevel}
)|
(
	$D_GLOBALS_INTENT_VOLUMEMIN {_intent=D_GLOBALS_INTENT_VOLUMEMIN._intent}
							{_volumeLevel=D_GLOBALS_INTENT_VOLUMEMIN._volumeLevel}
)|
(
	$D_GLOBALS_INTENT_VOLUMEUP {_intent=D_GLOBALS_INTENT_VOLUMEUP._intent} {_volumeLevel='null'}
)|
(
	$D_GLOBALS_INTENT_VOLUMEDOWN {_intent=D_GLOBALS_INTENT_VOLUMEDOWN._intent} {_volumeLevel='null'}
)|
(
	$D_GLOBALS_INTENT_VOLUMETOVALUE {_intent=D_GLOBALS_INTENT_VOLUMETOVALUE._intent}
							{_volumeLevel=D_GLOBALS_INTENT_VOLUMETOVALUE._volumeLevel}
)
;

### INTENTS ###
D_GLOBALS_INTENT_MAINMENU =
    ?($D_GLOBALS_V_GOTO $*) main menu {_intent='mainMenu'}
;

D_GLOBALS_INTENT_WHATCANIDO = (
	((what $* (can | may) (i | we | you) do) |
	(what are (my | our | the) options) |
	(what options ((can (i | we) choose ?from) | (are available)))  |
	(what ((are we) | (am i)) doing )) {_intent='whatCanIDo'}
);

D_GLOBALS_INTENT_HELP =
	(help |
	((i am) | (we are) | (i\'m) confused | puzzled) |
	(( i | we) ( do not | don\'t) understand) |
	(what ((do you) | (does that)) mean) |
	(that (does not | did not) make sense)) {_intent='help'}
;

D_GLOBALS_INTENT_STOP =
	((stop ?(it | that|(?the $SKILL_NAMES)|(playing ?($w03 [game?s]|music)))) |
	cancel |
	(quit (?it|(?the $SKILL_NAMES))) |
	(no more music|dancing|(playing $w03 [game?s]|music)) |
	(?that\'s enough) |
	(that will do) |
	(that\'ll do) |
	(?be quiet) |
	(shut $* up) |
	(be silent) |
	(cut (it | that) out) |
	(stop talking) |
	silence |
	(clothes gallery) |
	(clothes [picture?s]) |
	(exit ?(?the $SKILL_NAMES))|
	(close ?the $SKILL_NAMES)) {_intent='stop'}
;

D_GLOBALS_INTENT_SLEEP =
	((sleep ~4) |
	(go ?to sleep|bed) |
	(take ?a nap) |
	([you?(r|(\'re))] are|(?are $w03 [look?(ing)]) $w03 tired|tire|tiered) |
	(quit for today|tonight|(the night)) |
	(?(it\'s|(it is)) time (for ?you ?(to ?(go to)))|(to ?(go to)) bed|sleep) |
	(?([it?(\')s]|(it ?is)) time (?to take)|(for ?(you ?to take)) ?a nap) |
	([it?(\')s]|(it ?is) ?your bedtime|naptime|(nap time))){_intent='sleep'}
;


D_GLOBALS_INTENT_HOLDON =
	((hold on) |
	pause |
	(hold that thought) |
	wait |
	((one | a) (moment | minute))) {_intent='holdOn'}
;

D_GLOBALS_INTENT_OVERHERE =
	(
		(
			(
				((i\'m|(i am)|(we are)|we\'re)?(over|right)) |
				(over|right)
			)
			(
				(here|(this (direction|way))) |
				(to (your|the) (left|right))
			)
		) |
		(
			?((can|could|would) you) ?please
			(
				(
					(look|turn)
					(
						(?(over|right) here) |
						((at|to|toward|towards) ?(your|the) (left|right)) |
						(?(to your) back) |
						((at|to) (me|us)) |
						(?around ?in this (way|direction)) |
						(?around (toward|towards) (me|us|here))
					)
				) |
				(
					face
					(
						(?(toward|towards)(me|us|here)) |
						(?(toward|towards|in)(this (way|direction)))
					)
				)
			)
		)
	) {_intent='overHere'}
;

D_GLOBALS_INTENT_TURN_AWAY = (
    ((turn|look away|elsewhere|$D_GLOBALS_V_OTHER_PLACE)|lookaway ?($w03 from ?(me|us))) |
    (turn|$D_GLOBALS_V_LOOK ?(at) $w03 (other than)|(that\'s|(that is) not)|(that isn\'t) me|us|(my|our <1.0>+$w<0.0>)) |
    (([giv(e|(ing))] ?(me|us))|(i|we $w03 need|like|want) $w03 privacy) |
	(avert your [eye?s]|gaze) |
    (don\'t|(?do not)|stop|quit $w03 $D_GLOBALS_V_LOOK $w03 me|us|(my|our <1.0>+$w<0.0>))
){_intent='turnAway'};

D_GLOBALS_INTENT_TURN_AROUND = (
	((turn|spin around) ~10)
){_intent='turnAround'};


D_GLOBALS_INTENT_REPEAT =
   ((repeat ?that) |
   (come again) |
   (say $* again) |
   (?i\'m sorry) |
   (once more) |
   (one more time)) {_intent='repeat'}
;

